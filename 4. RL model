import warnings
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.ticker as ticker
import pybamm

warnings.filterwarnings("ignore")

N_CYCLES = 1

experiment = pybamm.Experiment(
    [(
        "Discharge at 1C until 2.0 V",
        "Rest for 5 minutes",
        "Charge at 1C until 4.15 V",
        "Hold at 4.15 V until C/50",
        "Rest for 5 minutes",
    )] * N_CYCLES,
)

# ── Experimental data (from calibration_Dsd script) ──────────────────────────
exp_cycles = np.array([  1, 100, 200, 300, 400, 500,
                        600, 700, 800, 900,1000,1100,
                       1200,1300,1400,1500])
exp_cap    = np.array([100.0, 99.4, 98.8, 98.2, 97.7, 97.2,
                        96.7,  96.1, 95.5, 94.9, 94.2, 93.2,
                        92.1,  91.0, 89.9, 89.0])

options = {
    "SEI": "reaction limited",
    "SEI film resistance": "average",
}

model = pybamm.lithium_ion.DFN(options=options)

param = pybamm.ParameterValues("Chayambuka2022")

param.update({
    "Negative electrode thickness [m]": 64e-6,
    "Positive electrode thickness [m]": 68e-6,
    "Separator thickness [m]": 25e-6,
    "Electrode height [m]": 0.0159,
    "Electrode width [m]": 0.0159,
    "Negative electrode active material volume fraction": 1 - 0.51 - 0.001,
    "Negative electrode porosity": 0.51,
    "Negative particle radius [m]": 3.48e-6,
    "Maximum concentration in negative electrode [mol.m-3]": 14540.0,
    "Initial concentration in negative electrode [mol.m-3]": 14520.0,
    "Negative electrode conductivity [S.m-1]": 256.0,
    "Negative electrode Bruggeman coefficient (electrolyte)": 1.5,
    "Negative electrode Bruggeman coefficient (electrode)": 1.5,
    "Positive electrode active material volume fraction": 1 - 0.23 - 0.22,
    "Positive electrode porosity": 0.23,
    "Positive particle radius [m]": 0.59e-6,
    "Maximum concentration in positive electrode [mol.m-3]": 15320.0,
    "Initial concentration in positive electrode [mol.m-3]": 3320.0,
    "Positive electrode conductivity [S.m-1]": 50.0,
    "Positive electrode Bruggeman coefficient (electrolyte)": 1.5,
    "Positive electrode Bruggeman coefficient (electrode)": 1.5,
    "Separator porosity": 0.55,
    "Cation transference number": 0.45,
    "Initial concentration in electrolyte [mol.m-3]": 1000.0,
    "Nominal cell capacity [A.h]": 2.8e-3,
    "Lower voltage cutoff [V]": 2.0,
    "Upper voltage cutoff [V]": 4.15,
    "Ambient temperature [K]": 298.15,
    "Initial temperature [K]": 298.15,
    "SEI partial molar volume [m3.mol-1]": 5.72e-5,
    "SEI resistivity [Ohm.m]": 2e5,
    "Bulk solvent concentration [mol.m-3]": 7500.0,
    "Initial SEI thickness [m]": 1e-9,
    "SEI growth activation energy [J.mol-1]": 0.0,
    "Ratio of lithium moles to SEI moles": 2.0,
    "SEI reaction exchange current density [A.m-2]": 2.4e-9,
    "SEI open-circuit potential [V]": 0.4,
})

try:
    solver = pybamm.IDAKLUSolver(atol=1e-4, rtol=1e-4)
except Exception:
    solver = pybamm.CasadiSolver(mode="safe", atol=1e-4, rtol=1e-4)

sim = pybamm.Simulation(
    model=model,
    parameter_values=param,
    experiment=experiment,
    solver=solver,
)

print("Running RL model...")
sol = sim.solve()

cycles = []
capacities = []

for i, cycle_sol in enumerate(sol.cycles):
    try:
        cap = cycle_sol.steps[0]["Discharge capacity [A.h]"].entries[-1]
        cycles.append(i + 1)
        capacities.append(abs(cap) * 1000)
    except Exception:
        pass

cycles = np.array(cycles)
capacities = np.array(capacities)
capacity_pct = 100 * capacities / capacities[0]

slope = np.polyfit(cycles, capacity_pct, 1)[0]

print(f"  Slope = {slope:.4f} %/cycle  |  "
      f"Final retention = {capacity_pct[-1]:.2f}% after {len(cycles)} cycles")

# ── Per-100-cycle fade summary ────────────────────────────────────────────
print(f"\n  {'Cycle Range':<20} {'Start (%)':>10} {'End (%)':>10} {'Fade (%)':>10}")
print(f"  {'-'*52}")

checkpoints = list(range(0, N_CYCLES, 100)) + [N_CYCLES - 1]
for k in range(len(checkpoints) - 1):
    c_start = checkpoints[k] + 1
    c_end   = checkpoints[k + 1] + 1

    idx_start = np.searchsorted(cycles, c_start)
    idx_end   = np.searchsorted(cycles, c_end)

    if idx_start >= len(cycles) or idx_end >= len(cycles):
        break

    cap_start = capacity_pct[idx_start]
    cap_end   = capacity_pct[idx_end]
    fade      = cap_start - cap_end

    print(f"  Cycle {c_start:>4} → {c_end:>4}   "
          f"{cap_start:>10.3f} {cap_end:>10.3f} {fade:>10.4f}")

print()

# ============================================================
# PLOT
# ============================================================

fig, ax = plt.subplots(figsize=(7, 5))

ax.plot(cycles, capacity_pct, linewidth=2, label="RL model", color="blue")

# ── Overlay experimental data ─────────────────────────────────────────────────
ax.scatter(exp_cycles, exp_cap, color="deeppink", s=60,
           marker="x", linewidths=1.8, zorder=5, label="Experimental")

ax.set_title("Capacity fade for 1500 cycles", fontsize=12)

# ── Axes formatting (matching paper style) ────────────────────────────────────
ax.set_xlabel("Cycle number", fontsize=13, fontweight="bold")
ax.set_ylabel("Capacity (%)", fontsize=13, fontweight="bold")
ax.set_xlim(80, 1500)
ax.set_ylim(80, 100)
ax.set_xticks([ 300, 600, 900, 1200, 1500])
ax.set_yticks([80, 85, 90, 95, 100])
ax.tick_params(axis="both", labelsize=11, direction="in",
               top=True, right=True, length=5)
ax.xaxis.set_minor_locator(ticker.AutoMinorLocator(3))
ax.yaxis.set_minor_locator(ticker.AutoMinorLocator(5))
ax.tick_params(which="minor", direction="in", top=True, right=True, length=3)
ax.grid(True, linestyle="--", alpha=0.35, color="gray")

# ── Legend (matching paper — lower left, box) ────────────────────────────────
legend = ax.legend(fontsize=10, loc="lower left",
                   frameon=True, framealpha=1.0,
                   edgecolor="black", fancybox=False)

# ── Spine styling (thick border like paper) ───────────────────────────────────
for spine in ax.spines.values():
    spine.set_linewidth(1.5)

plt.tight_layout()
plt.savefig("rl_model_experimental.png", dpi=200, bbox_inches="tight")
plt.show()
print("\nSaved → rl_model_experimental.png")
