base_fade = summary["Base SEI SD model"][2]
for lbl, (cyc, cap, fade) in list(summary.items())[1:]:
    clean = lbl.replace("$", "").replace("\\", "").replace("{", "").replace("}", "")
    extra = fade - base_fade
